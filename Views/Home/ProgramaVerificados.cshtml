@{
    ViewData["Title"] = "Programa de Verificados";
}

<div class="ayuda-container" style="text-align: center;">
    <div style="margin-bottom: 30px;">
        <img src="~/images/Verify.png" alt="Verify Logo" style="max-width: 250px; height: auto;">
    </div>

    <h1 style="color: #00d9ff; font-weight: bold; font-size: 2.5rem; margin-bottom: 25px;">PROGRAMA DE VERIFICADOS</h1>

    <div style="display: inline-block; background-color: white; color: #17445c; padding: 15px 40px; border-radius: 50px; font-weight: 500; font-size: 1.2rem; margin-bottom: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
        Unete al programa de verificados PAMACEA
    </div>

    <h2 style="color: #00d9ff; font-weight: bold; font-size: 2rem; margin-top: 30px; margin-bottom: 20px;">¿Que es el programa de Verificados PAMACEA?</h2>

    <div class="cuadro" style="text-align: left; padding: 30px; line-height: 1.6; margin-bottom: 30px;">
        <p style="margin-bottom: 15px; font-size: 1.1rem; color: #17445c;">
            Es un proceso diseñado para validar la identidad de los profesionales de la salud que busquen formar parte de nuestra plataforma.
        </p>
        <p style="font-size: 1.1rem; color: #17445c;">
            Tenemos como objetivo conectar a los usuarios con especialistas reales, certificados y que ofrezcan atencion de calidad.
        </p>
    </div>

    <h2 style="color: #00d9ff; font-weight: bold; font-size: 2rem; margin-top: 30px; margin-bottom: 20px;">¿Qué significa estar Verificado por PAMACEA?</h2>
    
    <div class="cuadro" style="text-align: left; padding: 30px; line-height: 1.6; margin-bottom: 30px;">
        <p style="font-size: 1.1rem; color: #17445c;">
            Un profesional verificado es quien ha pasado un proceso de revisión documental y validación
            para ser recomendado en el apartado de "Verificados PAMACEA" en el que el objetivo
            es conectar a usuarios con especialistas y conectar a los especialistas con potenciales pacientes.
        </p>
    </div>

    <h2 style="color: #00d9ff; font-weight: bold; font-size: 2rem; margin-top: 30px; margin-bottom: 20px;">¿Tiene algún costo?</h2>
    
    <div class="cuadro" style="text-align: left; padding: 30px; line-height: 1.6; margin-bottom: 30px;">
        <p style="font-size: 1.1rem; color: #17445c;">
            El programa de Verificados PAMACEA tiene un costo de $200.M.X mensuales (puede cancelar).
        </p>
    </div>

    <h2 style="color: #00d9ff; font-weight: bold; font-size: 2rem; margin-top: 30px; margin-bottom: 20px;">Proceso de Verificación</h2>
    
    <div class="cuadro" style="text-align: left; padding: 30px; line-height: 1.6; margin-bottom: 30px;">
        <p style="font-size: 1.1rem; color: #17445c; white-space: pre-line;">
            1. El profesional interesado rellena el formulario con sus datos.
            2. El equipo de PAMACEA verifica que sea verídico.
            3. Se le envía una respuesta al interesado ya sea aprobado o denegado el permiso.
            4. PAMACEA envía la clave interbancaria para realizar un pago de $200.M.X mensuales (puede cancelar).
            5. Una vez completado el proceso el profesional formará parte del programa y tendrá un espacio en Verificados.
            
            <strong>NOTA:</strong> La duración de la verificación debe renovarse cada mes para seguir formando parte del programa.
        </p>
    </div>

    <h2 style="color: #00d9ff; font-weight: bold; font-size: 2rem; margin-top: 40px; margin-bottom: 25px;">Rellena el siguiente formulario para formar parte de PAMACEA</h2>
    
    <div class="action-button-container" style="margin-top: 20px; margin-bottom: 50px;">
        <a href="https://forms.gle/u2SZTqnBUy74is8H9" class="custom-blue-btn">Formulario de Verificación</a>
    </div>
</div>

<style>
    .custom-blue-btn {
        display: inline-block;
        background: linear-gradient(135deg, #0c86c3 0%, #0a6fa3 100%);
        color: white;
        padding: 18px 45px;
        border-radius: 50px;
        font-weight: bold;
        font-size: 1.2rem;
        text-decoration: none;
        box-shadow: 0 4px 15px rgba(12, 134, 195, 0.4);
        transition: all 0.3s ease;
    }

    .custom-blue-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(12, 134, 195, 0.6);
        color: white;
        text-decoration: none;
    }

    .cuadro {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }
</style>
